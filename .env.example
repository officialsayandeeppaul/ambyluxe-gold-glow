# ============================================================================
# Copy this file to .env (root), then fill values.
# Do NOT commit .env.
# ============================================================================
# Quick start:
# 1) Backend: run Medusa in /backend (see backend/README.md)
# 2) Storefront: npm run dev (http://localhost:8080)
# ============================================================================

# Base URL of Medusa backend Store API.
# Local default when backend runs with `npm run dev` in /backend.
VITE_MEDUSA_URL=http://localhost:9000

# REQUIRED for live Medusa data (without it, the app uses static demo products).
# Get the key in seconds (Docker Postgres + seeded DB):
#   cd backend && npm run print-publishable-key
# Or: Medusa Admin → Settings → Publishable API keys → copy token (pk_...).
VITE_MEDUSA_PUBLISHABLE_KEY=pk_replace_with_your_key

# Store uses INR only — match Medusa’s India region (or re-seed with backend npm run seed).
# Each Medusa region you add appears as its own price column in Admin (e.g. “Price INR” + “Price <region>”).
# Pin one region for the storefront: set VITE_MEDUSA_REGION_ID, or rely on VITE_MEDUSA_DEFAULT_CURRENCY.
# VITE_MEDUSA_REGION_ID=reg_xxxxxxxx
VITE_MEDUSA_DEFAULT_CURRENCY=inr

# INR: Medusa stores prices in paise; the storefront divides by 100. If Admin sometimes saves the
# sale price as rupees in the minor field (API shows 5000 but you meant ₹5,000), set this to true
# (default) so we compare against metadata compare_at_price and fix display. Set false for strict paise-only.
# VITE_MEDUSA_INR_AMBIGUOUS_HEURISTIC=true

# Optional: if cart create fails or variants are missing from cart, set the default sales channel id
# (Medusa Admin → Settings → Sales channels → copy id, e.g. sc_01...)
# VITE_MEDUSA_SALES_CHANNEL_ID=

# Razorpay Checkout (browser). Use the same Key ID as backend RAZORPAY_KEY_ID (public).
# If the dashboard says the key expired, generate new test keys and update both root .env and backend/.env.
# VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Google Maps JavaScript API + Places (checkout address autocomplete, India-only). Reduces “junk address” rejections in couriers.
# Cloud Console: enable “Maps JavaScript API” and “Places API”; restrict key by HTTP referrer (e.g. http://localhost:8080/*).
# VITE_GOOGLE_MAPS_API_KEY=

# Product metadata: see storefront /admin/metadata-guide (fixed keys; booleans = true/false text).

# Optional admin URL for the button/link in storefront admin hub.
# If omitted, app uses: ${VITE_MEDUSA_URL}/app
# VITE_MEDUSA_ADMIN_URL=http://localhost:9000/app

# Optional: provider id for Google auth in Medusa.
# If not set, Google button is hidden on storefront auth page.
# In Google Cloud OAuth client, add Authorized redirect URI:
# http://localhost:8080/auth/callback
# VITE_MEDUSA_AUTH_GOOGLE_PROVIDER=google

# Optional: phone OTP provider ids (comma separated, tried in order).
# If not set, the Mobile tab on /auth is disabled (Email-only auth).
# Use ids that match Medusa backend auth providers (see backend/medusa-config.ts).
# For Twilio Verify in backend/.env (TWILIO_*), set:
# VITE_MEDUSA_AUTH_PHONE_PROVIDER=phone
#
# Mobile sign-up: OTP → password creates the account (needs Twilio in backend).
# Mobile sign-in: phone + password only (no OTP); uses internal login id {digits}@phone.local.

# --- Who can open the STOREFRONT /admin hub (not Medusa Admin) ---
# Comma-separated customer emails that may visit /admin, /admin/login after signing in on the site.
# This is a storefront gate only. Medusa Admin users are separate (see backend/.env.template).
# VITE_STORE_ADMIN_EMAILS=you@example.com,ops@example.com

# WhatsApp floating chat button (storefront bottom-right).
# Set number with country code digits only (no +, no spaces), e.g. 919876543210
# If VITE_WHATSAPP_NUMBER is empty, the floating WhatsApp button is hidden.
# VITE_WHATSAPP_NUMBER=919876543210
# Optional prefilled text shown in WhatsApp chat:
# VITE_WHATSAPP_MESSAGE=Hi Amby Luxe, I need help with my order.

# --- Medusa Admin (dashboard at http://localhost:9000/app) ---
# Do NOT put Medusa admin email/password here (this file is for the Vite app).
# Create the backend admin user once from the backend folder:
#   npm run user:create -- admin@yourdomain.com YourSecurePassword
# Then log in at localhost:9000/app with that email and password.
