{
  "name": "backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "postinstall": "patch-package --exclude '^@medusajs/dashboard$'",
    "build": "medusa build",
    "db:migrate": "medusa db:migrate",
    "deploy:prepare": "npm run db:migrate && npm run ensure:inr && npm run ensure:collections && npm run seed:promotions",
    "deploy:prepare:prod": "npm run db:migrate && npm run ensure:inr:prod && npm run ensure:collections:prod && npm run seed:promotions:prod",
    "db:reset": "node ./scripts/reset-dev-db.cjs",
    "print-publishable-key": "node ./scripts/print-publishable-key.cjs",
    "shiprocket:test-auth": "medusa exec ./src/scripts/shiprocket-test-auth.ts",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:prod": "node ./scripts/medusa-exec-server.cjs src/scripts/seed.js",
    "seed:promotions": "medusa exec ./src/scripts/seed-promotions.ts",
    "seed:promotions:prod": "node ./scripts/medusa-exec-server.cjs src/scripts/seed-promotions.js",
    "ensure:inr": "medusa exec ./src/scripts/ensure-inr-only.ts",
    "ensure:inr:prod": "node ./scripts/medusa-exec-server.cjs src/scripts/ensure-inr-only.js",
    "ensure:collections": "medusa exec ./src/scripts/ensure-collections.ts",
    "ensure:collections:prod": "node ./scripts/medusa-exec-server.cjs src/scripts/ensure-collections.js",
    "backfill:variant-codes": "medusa exec ./src/scripts/backfill-variant-compliance-codes.ts",
    "backfill:variant-sku": "medusa exec ./src/scripts/backfill-variant-sku.ts",
    "backfill:variant-physical": "medusa exec ./src/scripts/backfill-variant-physical-from-product.ts",
    "backfill:seed-inr-prices": "medusa exec ./src/scripts/backfill-seed-inr-prices.ts",
    "backfill:product-handles": "medusa exec ./src/scripts/backfill-product-handles.ts",
    "start": "medusa start -H 0.0.0.0 -p 9000",
    "start:railway": "node ./scripts/railway-start.cjs",
    "redis:up": "docker compose -f ../docker-compose.yml up -d redis",
    "dev": "node ./scripts/ensure-redis.cjs && medusa develop -H 0.0.0.0 -p 9000",
    "user:create": "node ./scripts/create-admin-user.cjs",
    "user:create:prod": "node ./scripts/medusa-user-server.cjs",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/cli": "2.13.1",
    "@medusajs/core-flows": "^2.13.1",
    "@medusajs/framework": "2.13.1",
    "@medusajs/js-sdk": "2.13.1",
    "@medusajs/medusa": "2.13.1",
    "@medusajs/ui": "4.1.1",
    "@sgftech/payment-razorpay": "^2.1.11",
    "razorpay": "^2.9.6",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.1",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
