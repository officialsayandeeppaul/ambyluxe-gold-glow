# Copy to .env (see README). Local dev with repo-root: docker compose up -d
MEDUSA_ADMIN_ONBOARDING_TYPE=default

# Admin UI: open http://127.0.0.1:9000/app if "localhost" refuses to connect (Windows / DNS).
# Dev server binds 0.0.0.0:9000 via npm run dev (see backend/package.json).

# Vite storefront (this repo) runs on 8080 — must be listed for browser API calls
STORE_CORS=http://localhost:8080,http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:8080,http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com

# Auto-generate HS/MID on products (parent) and variants (child suffix from parent id). Set true to allow manual codes in Admin.
# MEDUSA_DISABLE_AUTO_VARIANT_COMPLIANCE_CODES=false

# Auto-set variant SKU when empty (AMB-{productId}-{variantId} from internal ids). Set true to force manual SKUs only.
# MEDUSA_DISABLE_AUTO_SKU=false
#
# Slugify product handles and enforce uniqueness (storefront /products/{handle}).
# MEDUSA_DISABLE_AUTO_PRODUCT_HANDLE=false

# Copy product weight/dimensions/origin/material onto variants when variant fields are empty (Admin variant drawer matches product).
# MEDUSA_DISABLE_SYNC_VARIANT_PHYSICAL=false

# Redis is required — without it http://localhost:9000/app often hangs / [ioredis] ECONNRESET.
# From backend/: npm run redis:up   (Docker)   then: npm run dev
# Or repo root: docker compose up -d redis
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Matches docker-compose.yml in repo root (postgres service)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/medusa?sslmode=disable

# Optional Google OAuth provider for customer auth.
# 1) Create OAuth client in Google Cloud Console.
# 2) Authorized redirect URI must match:
#    http://localhost:8080/auth/callback
# 3) Set these values, then restart backend.
# MEDUSA_GOOGLE_PROVIDER_ID=google
# MEDUSA_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# MEDUSA_GOOGLE_CLIENT_SECRET=your-google-client-secret
# MEDUSA_GOOGLE_CALLBACK_URL=http://localhost:8080/auth/callback

# Optional Twilio Verify phone OTP provider for customer auth.
# 1) Twilio Console -> Verify -> Services -> create service -> copy Service SID (VA...)
# 2) Twilio Console -> Account -> copy Account SID + Auth Token
# 3) Set these values, then restart backend.
# MEDUSA_PHONE_PROVIDER_ID=phone
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 4) Twilio Console → Verify → your Service → Settings: set Friendly name (e.g. Amby Luxe Jewels) so SMS reads professionally.

# --- Medusa Admin (http://localhost:9000/app) — NOT the Vite site /admin/login ---
# Create user:  npm run user:create -- you@example.com YourPassword
# Sign in only at :9000/app. The storefront /admin hub uses customer accounts + VITE_STORE_ADMIN_EMAILS (repo-root .env).
#
# Extra variant price columns (EUR/USD/weird codes) = extra store currencies or non-INR regions.
# India-only: from backend/ run  npm run ensure:inr  then refresh Admin (INR-only store; soft-deletes non-INR regions).

# --- Razorpay (Store checkout) ---
# Keys: https://dashboard.razorpay.com/app/keys
# Webhook URL (production): https://<your-backend>/hooks/payment/razorpay_razorpay
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# Optional linked account (Route): RAZORPAY_ACCOUNT=

# --- Shiprocket (push order on Medusa order.placed) ---
# 1) Shiprocket → Settings → API: create API user → email + password (not your main login).
# 2) Pickup location name must match exactly: Shiprocket → Settings → Pickup locations.
# 3) Put these in backend/.env (not the Vite root .env) and restart Medusa.
# 4) SHIPROCKET_ENABLED must be truthy: true, 1, yes, or on (not "True" with wrong file = use lowercase or 1).
# SHIPROCKET_ENABLED=true
# SHIPROCKET_API_EMAIL=api-user@yourdomain.com
# SHIPROCKET_API_PASSWORD=your_api_user_password
# IMPORTANT: Medusa loads .env with dotenv-expand — a password starting with $ breaks auth (wrong password sent).
# Fix: prefix each $ with backslash, e.g. SHIPROCKET_API_PASSWORD=\$9my\$pass
# Or use base64 (no escaping):  node -e "console.log(Buffer.from('YOUR_PASSWORD','utf8').toString('base64'))"
# SHIPROCKET_API_PASSWORD_B64=base64_here
# Or a file (one line, raw password; add to .gitignore): SHIPROCKET_API_PASSWORD_FILE=.shiprocket-password
# Aliases (same effect): SHIPROCKET_EMAIL, SHIPROCKET_PASSWORD
#
# Test credentials (same as running server):  cd backend && npm run shiprocket:test-auth
# After “too many logins”, backend stops calling Shiprocket for this many ms (default 1h) to avoid extending the block.
# SHIPROCKET_LOCKOUT_BACKOFF_MS=3600000
# SHIPROCKET_PICKUP_LOCATION=Primary
# Alias: SHIPROCKET_PICKUP=Primary  (same meaning if you prefer shorter name)
# Optional: SHIPROCKET_CHANNEL_ID=12345
# Optional: force payment label — Prepaid | COD (default: Prepaid if order has capture transactions, else COD)
# SHIPROCKET_PAYMENT_METHOD=Prepaid
# Map Medusa shipping method name → Shiprocket checkout_shipping_method (optional; defaults below if name contains "express" / "standard")
# SHIPROCKET_SR_METHOD_STANDARD=SR_STANDARD
# SHIPROCKET_SR_METHOD_EXPRESS=SR_EXPRESS
# SHIPROCKET_CHECKOUT_SHIPPING_METHOD=SR_STANDARD   (fallback when name matches neither)
# Package defaults (Shiprocket requires length/breadth/height cm and weight kg > 0)
# SHIPROCKET_PACKAGE_LENGTH_CM=10
# SHIPROCKET_PACKAGE_BREADTH_CM=10
# SHIPROCKET_PACKAGE_HEIGHT_CM=10
# SHIPROCKET_PACKAGE_WEIGHT_KG=0.5
# If address phone missing, 10-digit fallback (India): SHIPROCKET_FALLBACK_PHONE=9999999999
# If order.email empty (avoid in production): SHIPROCKET_FALLBACK_EMAIL=ops@yourdomain.com
# Token cache duration (days, default 9): SHIPROCKET_TOKEN_CACHE_DAYS=9

# --- Brevo (order receipt email + optional WhatsApp) ---
# Free tier: transactional emails (daily cap in Brevo). Create API key: Brevo → SMTP & API → API keys.
# Verify sender domain or single sender email in Brevo before go-live.
#
# BREVO_ENABLED=true
# BREVO_API_KEY=xkeysib-...
# BREVO_SENDER_EMAIL=noreply@your-verified-domain.com
# BREVO_SENDER_NAME=Amby Luxe Jewels
# STORE_PUBLIC_URL=https://your-storefront.example   (links in emails)
# MEDUSA_BACKEND_PUBLIC_URL=https://api.your-domain.example   (no trailing slash — absolutize /static/… thumbnails in Brevo template params)
#
# Order placed (subscriber: order.placed):
# 1) If order/customer has a valid email → send HTML receipt via Brevo /smtp/email (or template below).
# 2) Else if BREVO_ORDER_WHATSAPP_TEMPLATE_ID + BREVO_WHATSAPP_SENDER_NUMBER → WhatsApp to shipping/customer phone.
#    Template in Brevo must be approved; params passed: ORDER_DISPLAY_ID, ORDER_TOTAL, CURRENCY
# Optional: Brevo SMTP/transactional template id (Campaigns → Marketing template ids often fail on /smtp/email).
# If set and Brevo rejects it, the subscriber retries with built-in HTML. Use a Transactional (SMTP) template in Brevo — not only a Newsletters design — or params may not merge.
# In Brevo: {{ params.ORDER_BODY_INTRO }} (one block) or two blocks {{ params.ORDER_BODY_INTRO_LINE1 }} / {{ params.ORDER_BODY_INTRO_LINE2 }} | image → {{ params.FIRST_LINE_ITEM_IMAGE_URL }} | alt → {{ params.FIRST_LINE_ITEM_TITLE }}
# Params: ORDER_TOTAL uses order grand total (money objects + line fallbacks). Images: set MEDUSA_BACKEND_PUBLIC_URL to a public https Medusa host — localhost URLs break in Gmail; Brevo fetches images server-side.
# BREVO_ORDER_EMAIL_TEMPLATE_ID=
# BREVO_ORDER_WHATSAPP_TEMPLATE_ID=
# BREVO_WHATSAPP_SENDER_NUMBER=91xxxxxxxxxx    (digits only, country code, no + — your Brevo WhatsApp sender)
#
# Welcome / marketing on first account (subscriber: customer.created) — off unless enabled
# BREVO_CUSTOMER_WELCOME_ENABLED=true
# BREVO_CUSTOMER_WELCOME_WHATSAPP_TEMPLATE_ID=     (params: FIRSTNAME, STORE_URL — match your approved template)
# BREVO_CUSTOMER_WELCOME_EMAIL_TEMPLATE_ID=       (optional; uses Brevo email template)
# WhatsApp needs Brevo WhatsApp connected + templates; SMS credits in Brevo are separate from email quota.
